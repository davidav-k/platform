# Development-only example values.
# Copy this file to .env for local development.
# Replace JWT_SECRET and every *_change_me value before using another environment.
# Never use these example values in shared, staging, or production environments.
#
# JWT_SECRET must be Base64-encoded because user-service and api-gateway decode it.
# This intentionally weak development value decodes to 64 repeated "A" bytes.
JWT_SECRET=QUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQQ==
ADMIN_PASSWORD=dev_example_admin_password_change_me

# PostgreSQL Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=users_db
POSTGRES_USER=user
POSTGRES_PASSWORD=dev_example_postgres_password_change_me

# Application Configuration (optional overrides with Spring defaults)
APPLICATION_PORT=8085
ACTIVE_PROFILE=dev

# Required by the Docker Compose user-service configuration.
JWT_EXPIRATION=432000

# Email Configuration
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_ID=dev_sender@example.local
EMAIL_PASSWORD=dev_example_email_password_change_me
EMAIL_VERIFY_HOST=http://localhost:8085
