# Development-only example values.
# Copy this file to .env for local development and replace every *_change_me value.
# Never use these example values in shared, staging, or production environments.
JWT_SECRET=dev_example_jwt_secret_change_me
ADMIN_PASSWORD=dev_example_admin_password_change_me

# PostgreSQL Configuration
POSTGRES_CONTAINER=users_container
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=users_db
POSTGRES_USER=user
POSTGRES_PASSWORD=dev_example_postgres_password_change_me

# Application Configuration
APPLICATION_PORT=8085
ACTIVE_PROFILE=dev

# Email Configuration
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_ID=sender@mail.com
EMAIL_PASSWORD=dev_example_email_password_change_me
EMAIL_VERIFY_HOST=http://localhost:8085

# pgAdmin Configuration
PGADMIN_EMAIL=user@mail.com
PGADMIN_PASSWORD=dev_example_pgadmin_password_change_me
