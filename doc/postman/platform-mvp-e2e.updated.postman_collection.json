    "name": "Platform MVP End-to-End - API Gateway",
    "description": "Gateway-only MVP verification for authentication, user activation, task ownership/RBAC, soft delete, Kafka-backed task-created in-app notifications, refresh, and the currently pending logout contract. Aligned with platform_240626_exclude.txt.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "function setVariable(name, value) {",
          "  pm.environment.set(name, value);",
          "  pm.collectionVariables.set(name, value);",
          "}",
          "function initializeRun() {",
          "  const runId = String(Date.now());",
          "  setVariable('runId', runId);",
          "  setVariable('taskTitle', 'Postman MVP task ' + runId);",
          "  setVariable('updatedTaskTitle', 'Postman MVP task updated ' + runId);",
          "  setVariable('assignedTaskTitle', 'Postman assigned task ' + runId);",
          "  setVariable('unrelatedTaskTitle', 'Postman admin task ' + runId);",
          "}",
          "if (pm.info.requestName === 'Gateway Health' || !pm.environment.get('runId')) initializeRun();"
        ]
      }
    }
  ],
