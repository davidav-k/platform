            "url": {
              "raw": "{{baseUrl}}/api/users/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"MVP\",\n  \"lastName\": \"User\",\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "A 201 creates a disabled USER account and sends a verification email to MailHog. A conflict/error for an existing email is acceptable only when that account was prepared previously."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Registration creates or finds prepared user', function () { pm.expect([201, 409]).to.include(pm.response.code); });",
                  "pm.test('Response is JSON', function () {",
                  "  pm.expect(pm.response.headers.get('Content-Type') || '').to.include('application/json');",
                  "});",
                  "if (pm.response.code === 201) { pm.test('Registration instructs account verification', function () { pm.expect(pm.response.json().message.toLowerCase()).to.include('account'); }); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify Regular User Account",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/verify/account?key={{verificationKey}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "verify",
                "account"
              ]
            },
            "description": "Set verificationKey from the MailHog verification link. This request is skipped when verificationKey is blank so prepared active users can run the collection."
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.environment.get('verificationKey') && !pm.collectionVariables.get('verificationKey')) {",
                  "  console.warn('Skipping account verification because verificationKey is blank.');",
                  "  pm.execution.skipRequest();",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Account verification succeeds', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON', function () {",
                  "  pm.expect(pm.response.headers.get('Content-Type') || '').to.include('application/json');",
                  "});"
                ]
              }
            }
          ]
        },
