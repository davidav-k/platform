    {
      "name": "01 - Admin and Regular User Setup",
      "description": "For a new regular user, run Register, copy the verification key from MailHog, set verificationKey, then run Verify before continuing. A full runner execution assumes the regular user is already active or verificationKey is populated.",
      "item": [
        {
          "name": "Login as Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Admin login succeeds', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON', function () {",
                  "  pm.expect(pm.response.headers.get('Content-Type') || '').to.include('application/json');",
                  "});",
                  "function setVariable(name, value) {",
                  "  if (value === undefined || value === null || value === '') return;",
                  "  pm.environment.set(name, String(value));",
                  "  pm.collectionVariables.set(name, String(value));",
                  "}",
                  "function cookieValue(name) {",
                  "  const headers = pm.response.headers.all().filter(h => h.key.toLowerCase() === 'set-cookie');",
                  "  for (const header of headers) {",
                  "    const match = header.value.match(new RegExp('(?:^|[,;]\\\\s*)' + name + '=([^;]+)'));",
                  "    if (match) return match[1];",
                  "  }",
                  "}",
                  "let body = {};",
                  "try { body = pm.response.json(); } catch (e) {}",
                  "const accessToken = cookieValue('access-token') || body.accessToken || body.access_token || body.data?.accessToken || body.data?.access_token || body.data?.tokens?.accessToken;",
                  "const refreshToken = cookieValue('refresh-token') || body.refreshToken || body.refresh_token || body.data?.refreshToken || body.data?.refresh_token || body.data?.tokens?.refreshToken;",
                  "setVariable('accessToken', accessToken);",
                  "setVariable('refreshToken', refreshToken);",
                  "const json = pm.response.json();",
                  "pm.test('Admin user is returned', function () { pm.expect(json.data?.user).to.be.an('object'); });",
                  "const adminUserId = json.data?.user?.userId;",
                  "pm.expect(adminUserId, 'admin public userId').to.be.a('string').and.not.empty;",
                  "pm.environment.set('adminUserId', adminUserId); pm.collectionVariables.set('adminUserId', adminUserId);",
                  "const access = pm.environment.get('accessToken'); const refresh = pm.environment.get('refreshToken');",
                  "pm.test('Admin cookies were extracted', function () { pm.expect(access).to.be.a('string').and.not.empty; pm.expect(refresh).to.be.a('string').and.not.empty; });",
                  "pm.environment.set('adminAccessToken', access); pm.collectionVariables.set('adminAccessToken', access);",
                  "pm.environment.set('adminRefreshToken', refresh); pm.collectionVariables.set('adminRefreshToken', refresh);"
                ]
              }
            }
          ]
        },
        {
          "name": "Register Regular User (idempotent setup)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
