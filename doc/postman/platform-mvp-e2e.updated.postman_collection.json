          "name": "Refresh Regular User Tokens",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Cookie",
                "value": "refresh-token={{userRefreshToken}}",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "refresh"
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Refresh succeeds', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON', function () {",
                  "  pm.expect(pm.response.headers.get('Content-Type') || '').to.include('application/json');",
                  "});",
                  "function setVariable(name, value) {",
                  "  if (value === undefined || value === null || value === '') return;",
                  "  pm.environment.set(name, String(value));",
                  "  pm.collectionVariables.set(name, String(value));",
                  "}",
                  "function cookieValue(name) {",
                  "  const headers = pm.response.headers.all().filter(h => h.key.toLowerCase() === 'set-cookie');",
                  "  for (const header of headers) {",
                  "    const match = header.value.match(new RegExp('(?:^|[,;]\\\\s*)' + name + '=([^;]+)'));",
                  "    if (match) return match[1];",
                  "  }",
                  "}",
                  "let body = {};",
                  "try { body = pm.response.json(); } catch (e) {}",
                  "const accessToken = cookieValue('access-token') || body.accessToken || body.access_token || body.data?.accessToken || body.data?.access_token || body.data?.tokens?.accessToken;",
                  "const refreshToken = cookieValue('refresh-token') || body.refreshToken || body.refresh_token || body.data?.refreshToken || body.data?.refresh_token || body.data?.tokens?.refreshToken;",
                  "setVariable('accessToken', accessToken);",
                  "setVariable('refreshToken', refreshToken);",
                  "const access = pm.environment.get('accessToken'); const refresh = pm.environment.get('refreshToken');",
                  "pm.test('Refresh rotates both cookies', function () { pm.expect(access).to.be.a('string').and.not.empty; pm.expect(refresh).to.be.a('string').and.not.empty; });",
                  "pm.environment.set('userAccessToken', access); pm.collectionVariables.set('userAccessToken', access); pm.environment.set('userRefreshToken', refresh); pm.collectionVariables.set('userRefreshToken', refresh);"
                ]
              }
            }
          ]
        },
